                                       i_debugger = me ).

    mo_tree_exp = NEW zcl_smd_rtti_tree( i_header   = 'Exporting & Returning parameters'
                                     i_type     = 'E'
                                     i_cont     = mo_window->mo_exporting_container
                                     i_debugger = me ).

    mo_tree_local->m_locals = mo_tree_local->m_locals BIT-XOR c_mask.

  ENDMETHOD.

  METHOD script.

    run_script( ).
    show_step( ).
    me->break( ).

  ENDMETHOD.

