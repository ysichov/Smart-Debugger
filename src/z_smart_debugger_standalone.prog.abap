    APPEND VALUE #( function  = 'RUN_PROGRAM'
                    icon      = CONV #( icon_execute_object )
                    butn_type = cntb_btype_button
                    text      = 'RUN program'
                    quickinfo = |Run { mv_run_program } via selection screen| ) TO lt_buttons.
    mo_toolbar->add_button_group( lt_buttons ).
